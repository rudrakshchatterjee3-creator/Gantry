GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
CENSUS_API_KEY=
AIRNOW_API_KEY=
TRANSITLAND_API_KEY=

# Session cookie signing secret (HS256 JWT). Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=

# Shared invite code required to create an official account at /welcome.
# Not a per-user credential — a single demo/deployment-wide gate. See
# SECURITY.md for why this is a real (if intentionally simple) access
# control rather than open self-registration.
#
# NOTE on the deployed Worker (not local dev): Cloudflare's git-connected
# Workers Build pipeline was confirmed NOT to inject dashboard-set
# Variables/Secrets into the deployed Worker's runtime env at all — a real
# production bug diagnosed via a temporary debug endpoint (see git history).
# OFFICIAL_INVITE_CODE is declared directly in wrangler.jsonc's `vars`
# instead (safe — it's shown in the signup UI anyway, not a real secret).
OFFICIAL_INVITE_CODE=

# Same value as OFFICIAL_INVITE_CODE, exposed to the client so the signup
# form can display it as a hint for judges/testers. This is a BUILD-TIME
# value (baked into the client bundle by `next build`), not a Worker
# runtime binding — for the deployed Worker it lives in .env.production
# (committed, since it's not secret), not wrangler.jsonc.
NEXT_PUBLIC_OFFICIAL_INVITE_CODE_HINT=
